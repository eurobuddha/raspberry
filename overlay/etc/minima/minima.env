# ============================================================
#  Minima Node Configuration
#  Uncomment and edit params as needed, then restart:
#    sudo systemctl daemon-reload && sudo systemctl restart minima-node
#
#  Port layout (based on MINIMA_PORT):
#    9001  P2P          (MINIMA_PORT)
#    9003  MDS Hub      (MINIMA_PORT + 2)
#    9004  MDS Commands (MINIMA_PORT + 3)
#    9005  RPC          (MINIMA_PORT + 4)
# ============================================================

# ── Core ──

MDS_PASSWORD=minima
#MINIMA_PORT=9001
#MINIMA_DATA=/home/minima/.minima
#MINIMA_HOST=

# ── Database ──
# AES encryption password for wallet/SQL. Set on FIRST launch only — cannot be changed later.
# Default "minima" means no encryption.
#MINIMA_DBPASSWORD=minima

# ── RPC ──
#MINIMA_RPCENABLE=true
#MINIMA_RPCPASSWORD=
#MINIMA_RPCSSL=false

# ── MDS (MiniDapp System) ──
#MINIMA_MDSENABLE=true
#MINIMA_MDSINIT=
#MINIMA_MDSWRITE=
#MINIMA_NOSSLMDS=false
#MINIMA_PUBLICMDS=false
#MINIMA_NODEFAULTMINIDAPPS=false

# ── Network / P2P ──
# -isclient: can't accept incoming connections (behind NAT)
# -server: explicitly accept incoming connections
# -nop2p: disable P2P entirely (private/solo node)
# -connect: disable P2P auto-discovery, connect only to specified host:port
#MINIMA_ISCLIENT=false
#MINIMA_SERVER=false
#MINIMA_NOP2P=false
#MINIMA_CONNECT=
#MINIMA_ALLOWALLIP=false
#MINIMA_P2PROOTNODE=
#MINIMA_P2PNODES=

# ── Node Mode ──
# -archive: store full chain history (heavy storage, needed for resyncing other nodes)
# -megammr: run in Mega MMR mode
# -daemon: no stdin (recommended for services, already set in systemd)
# -desktop: can't accept incoming P2P connections
# -solo: private network, no P2P (-test -nop2p), runs genesis on first boot only
#MINIMA_ARCHIVE=false
#MINIMA_MEGAMMR=false
#MINIMA_DAEMON=true
#MINIMA_DESKTOP=false
#MINIMA_SOLO=false

# ── Storage ──
# Days to keep TxPoW in internal H2 database (minimum 3)
#MINIMA_TXPOWDBSTORE=3
#MINIMA_BASEFOLDER=

# ── Recovery ──
# BIP39 seed phrase — only used when starting a NEW node
#MINIMA_SEED=
#MINIMA_ANYSEED=
#MINIMA_RESCUENODE=

# ── MySQL (optional external DB) ──
#MINIMA_MYSQLDB=username:password@host:port
#MINIMA_MYSQLDBCOINS=false
#MINIMA_MYSQLALLTXPOW=false

# ── Debugging ──
#MINIMA_SHOWPARAMS=false
#MINIMA_SHOWNETCALLS=false
#MINIMA_SHOWNETCALLSNOPOLL=false
#MINIMA_LIMITBANDWIDTH=false
